#!/bin/sh
# Managed by Codebase Analysis AI.
repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
checker="$repo_root/tools/codebase-analysis-ai/check.py"
[ -f "$checker" ] || exit 0

if git rev-parse HEAD^ >/dev/null 2>&1; then
  base="HEAD^"
else
  base=""
fi

if command -v python3 >/dev/null 2>&1; then py=python3
elif command -v python >/dev/null 2>&1; then py=python
elif command -v py >/dev/null 2>&1; then py="py -3"
else
  echo "Codebase Analysis AI: Python 3 was not found; check skipped." >&2
  exit 0
fi

if [ -n "$base" ]; then
  $py "$checker" check --mode post-commit --base "$base" --head HEAD --warn-only
else
  $py "$checker" check --mode post-commit --head HEAD --warn-only
fi
exit 0

